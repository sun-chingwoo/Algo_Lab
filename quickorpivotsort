#include <stdio.h>
#include <stdlib.h>
#include <time.h>

#define MAX 50000
int arr[MAX],n=5;

int partition(int low,int high){
    int pele=arr[high];
    int i=low-1;
    for(int j=low;j<high;j++){
        if(arr[j]<pele){
            i++;
            int temp=arr[i];
            arr[i]=arr[j];
            arr[j]=temp;
        }
    }
    int temp=arr[i+1];
    arr[i+1]=arr[high];
    arr[high]=temp;
    
    return i+1;
}

void quicksort(int low,int high){
    if(low<high){
        int pi=partition(low,high);
        quicksort(low,pi-1);
        quicksort(pi+1,high);
    }
}

int main(){
    for (int i = 5; i >=0; i--){
        arr[5-i]=i;
    }
    quicksort(0,n-1);
    for(int i=0;i<n;i++){
        printf("%d",arr[i]);
    }
    return 0;
}
