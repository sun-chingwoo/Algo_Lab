#include <stdio.h>

void heapify(int arr[],int n,int i){
    int root=i;
    int left=2*i+1;
    int right=2*i+2;
    
    if(left<n && arr[left]>arr[root]) root=left;
    if(right<n && arr[right]>arr[root]) root=right;
    
    if(root!=i){
        int temp=arr[root];
        arr[root]=arr[i];
        arr[i]=temp;
        
        heapify(arr,n,root);
    }
}

void heapsort(int arr[],int n){
    for(int i=n/2-1;i>=0;i--){
        heapify(arr,n,i);
    }
    
    for(int i=n-1;i>=0;i--){
        int temp=arr[i];
        arr[i]=arr[0];
        arr[0]=temp;
        
        heapify(arr,i,0);
    }
}

int main(){
    int arr[5]={3,2,4,5,1};
    int n=5;
    heapsort(arr,n);
    for(int i=0;i<n;i++){
        printf(" %d ",arr[i]);
    }
    return 0;
}
